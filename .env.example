# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
PORT=8080
HOST=0.0.0.0

# Database
DB_PATH=scaler.db

# Facebook Marketing API
FB_API_VERSION=v19.0

# Facebook OAuth (optional — enables "Login with Facebook")
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:8080/api/auth/facebook/callback

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# OpenAI (for AdsGPT — optional, falls back to built-in responses)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO
LOG_FILE=scaler.log
