# Flask
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false
PORT=8080
HOST=0.0.0.0

# Encryption key for sensitive tokens (Facebook, Telegram)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Database
DB_PATH=scaler.db

# Facebook OAuth (optional — can paste token directly in Settings)
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=
FB_API_VERSION=v19.0

# OpenAI (for AdsGPT chatbot)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS (comma-separated origins, or * for dev only)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
LOG_FILE=scaler.log
